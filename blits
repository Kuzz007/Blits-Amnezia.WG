change_port() {
    read -rp "Новый порт панели: " port
    if ! [[ "$port" =~ ^[0-9]+$ ]] || [ "$port" -lt 1 ] || [ "$port" -gt 65535 ]; then
        echo -e "${RED}Некорректный порт.${NC}"
        sleep 1.5
        return
    fi
    
    if ss -tulnp 2>/dev/null | grep -qE ":$port\s"; then
        echo -e "${YELLOW}Внимание: Порт $port уже используется каким-то процессом на сервере!${NC}"
        read -rp "Привязать панель к этому порту все равно? (y/n) [n]: " confirm
        if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
            return
        fi
    fi
    
    set_env PANEL_PORT "$port"
    python3 - "$DB_FILE" "$port" <<'PY' || true
import sqlite3, sys
db, port = sys.argv[1], sys.argv[2]
conn = sqlite3.connect(db)
conn.execute("insert or replace into settings(key,value) values('panel_port', ?)", (port,))
conn.commit()
conn.close()
PY
    restart_panel
    echo -e "${GREEN}Порт успешно изменен. Адрес: $(panel_url)${NC}"
    sleep 2
}

change_domain() {
    read -rp "Домен (без http:// и https://, пусто для сброса): " domain
    set_env PANEL_DOMAIN "$domain"
    python3 - "$DB_FILE" "$domain" <<'PY' || true
import sqlite3, sys
db, domain = sys.argv[1], sys.argv[2]
conn = sqlite3.connect(db)
conn.execute("insert or replace into settings(key,value) values('panel_domain', ?)", (domain,))
conn.commit()
conn.close()
PY
    restart_panel
    echo -e "${GREEN}Домен обновлен. Адрес: $(panel_url)${NC}"
    sleep 2
}

regenerate_web_path() {
    local old_path web_path
    old_path="$(get_env PANEL_WEB_PATH)"
    web_path="$(generate_web_path)"
    set_env PANEL_WEB_PATH "$web_path"
    restart_panel
    echo -e "Старый путь: ${old_path:-не задан}"
    echo -e "${GREEN}Новый секретный путь: $web_path${NC}"
    echo -e "Адрес входа: $(panel_url)"
    sleep 3
}

set_web_path() {
    read -rp "Новый секретный путь (например /blits-panel): " web_path
    web_path="/${web_path#/}"
    if [ "$web_path" = "/" ]; then
        echo -e "${RED}Путь по умолчанию / не разрешен в целях безопасности.${NC}"
        sleep 2
        return
    fi
    if ! [[ "$web_path" =~ ^/[A-Za-z0-9._~-]+$ ]]; then
        echo -e "${RED}Используйте только буквы, цифры, точки, дефисы и знаки подчеркивания.${NC}"
        sleep 2
        return
    fi
    set_env PANEL_WEB_PATH "$web_path"
    restart_panel
    echo -e "${GREEN}Секретный путь обновлен. Адрес: $(panel_url)${NC}"
    sleep 2
}

