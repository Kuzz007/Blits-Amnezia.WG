check_ports() {
    echo -e "${YELLOW}Проверка конфликтов портов...${NC}"
    local panel_port
    panel_port="$(get_env PANEL_PORT)"
    panel_port="${panel_port:-80}"
    
    echo "Заданный порт панели: $panel_port"
    if command -v ss >/dev/null 2>&1; then
        ss -tulnp | grep -E ":$panel_port\s" || echo -e "${GREEN}Порт $panel_port свободен на уровне хоста.${NC}"
    elif command -v netstat >/dev/null 2>&1; then
        netstat -tulnp | grep -E ":$panel_port\s" || echo -e "${GREEN}Порт $panel_port свободен на уровне хоста.${NC}"
    else
        echo -e "${YELLOW}Команда ss/netstat не найдена. Пробуем lsof...${NC}"
        if command -v lsof >/dev/null 2>&1; then
            lsof -i ":$panel_port" || echo -e "${GREEN}Порт $panel_port свободен.${NC}"
        else
            echo "Нет инструментов для диагностики портов. Установите net-tools или iproute2."
        fi
    fi
}

enable_bbr() {
    echo -e "${YELLOW}Включение оптимизации сети BBR Congestion Control...${NC}"
    if sysctl net.ipv4.tcp_congestion_control | grep -q bbr; then
        echo -e "${GREEN}Алгоритм BBR уже активирован на сервере!${NC}"
        return
    fi
    
    if ! modprobe tcp_bbr 2>/dev/null; then
        echo -e "${RED}Ошибка: модуль tcp_bbr не поддерживается ядром вашего сервера.${NC}"
        return
    fi
    
    echo "tcp_bbr" | tee /etc/modules-load.d/bbr.conf >/dev/null
    
    sed -i '/net.core.default_qdisc/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_congestion_control/d' /etc/sysctl.conf
    
    echo "net.core.default_qdisc=fq" >> /etc/sysctl.conf
    echo "net.ipv4.tcp_congestion_control=bbr" >> /etc/sysctl.conf
    
    sysctl -p >/dev/null
    
    if sysctl net.ipv4.tcp_congestion_control | grep -q bbr; then
        echo -e "${GREEN}Оптимизация BBR успешно включена! VPN будет работать стабильнее и быстрее.${NC}"
    else
        echo -e "${RED}Не удалось применить параметры sysctl для BBR.${NC}"
    fi
}

backup_db() {
    local backup_dir="$APP_DIR/backups"
    mkdir -p "$backup_dir"
    local timestamp
    timestamp=$(date +"%Y%m%d_%H%M%S")
    local backup_file="$backup_dir/blits_backup_$timestamp.tar.gz"
    
    echo -e "${YELLOW}Создание резервной копии базы данных и env...${NC}"
    tar -czf "$backup_file" -C "$APP_DIR" data/panel.db data/panel.env 2>/dev/null
    
    if [ -f "$backup_file" ]; then
        echo -e "${GREEN}Резервная копия создана: $backup_file${NC}"
    else
        echo -e "${RED}Ошибка при создании резервной копии.${NC}"
    fi
}

restore_db() {
    local backup_dir="$APP_DIR/backups"
    if [ ! -d "$backup_dir" ] || [ -z "$(ls -A "$backup_dir" 2>/dev/null)" ]; then
        echo -e "${RED}Резервные копии не найдены в папке $backup_dir${NC}"
        return
    fi
    
    echo -e "${YELLOW}Доступные резервные копии:${NC}"
    local idx=1
    declare -A backup_files
    for file in "$backup_dir"/blits_backup_*.tar.gz; do
        if [ -f "$file" ]; then
            echo "$idx) $(basename "$file")"
            backup_files[$idx]="$file"
            idx=$((idx + 1))
        fi
    done
    
    read -rp "Выберите номер бэкапа для восстановления (0 для отмены): " choice
    if [ "$choice" -eq 0 ] 2>/dev/null; then
        echo "Отмена."
        return
    fi
    
    local selected="${backup_files[$choice]:-}"
    if [ -z "$selected" ]; then
        echo -e "${RED}Неверный номер.${NC}"
        return
    fi
    
    read -rp "Вы уверены? Это перезапишет текущую базу и настройки! (y/n): " confirm
    if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
        echo "Отмена."
        return
    fi
    
    echo -e "${YELLOW}Восстановление базы данных...${NC}"
    docker stop amnezia-panel >/dev/null 2>&1 || true
    
    tar -xzf "$selected" -C "$APP_DIR"
    
    restart_panel
    echo -e "${GREEN}База данных успешно восстановлена, панель перезапущена!${NC}"
}

optimize_db() {
    echo -e "${YELLOW}Оптимизация и сжатие базы данных SQLite...${NC}"
    if run_py counts >/dev/null; then
        docker exec -i amnezia-panel python3 - <<'PY'
import sqlite3
try:
    conn = sqlite3.connect('/app/data/panel.db')
    conn.execute("VACUUM")
    conn.execute("PRAGMA optimize")
    conn.commit()
    conn.close()
    print("База данных успешно сжата и оптимизирована!")
except Exception as e:
    print(f"Ошибка оптимизации: {e}")
PY
    else
        echo -e "${RED}Ошибка: контейнер выключен. Невозможно оптимизировать БД.${NC}"
    fi
}

backups_menu() {
    while true; do
        clear
        echo -e "${CYAN}=========================================================================${NC}"
        echo -e "💾              ${BOLD}БЭКАПЫ, ОПТИМИЗАЦИЯ И СЕТЕВОЙ ТЮНИНГ${NC}                   💾"
        echo -e "${CYAN}=========================================================================${NC}"
        echo -e "  ${BOLD}1)${NC} Создать резервную копию базы данных и настроек"
        echo -e "  ${BOLD}2)${NC} Восстановить базу данных из бэкапа"
        echo -e "  ${BOLD}3)${NC} Очистить/Сжать базу данных (SQLite VACUUM)"
        echo -e "  ${BOLD}4)${NC} Включить ускорение сети BBR (для высокой скорости VPN)"
        echo -e "  ${BOLD}0)${NC} Назад в главное меню"
        echo -e "${CYAN}=========================================================================${NC}"
        
        read -rp "Выберите действие: " choice
        case "$choice" in
            1) backup_db ; read -rp "Нажмите Enter для продолжения..." ;;
            2) restore_db ; read -rp "Нажмите Enter для продолжения..." ;;
            3) optimize_db ; read -rp "Нажмите Enter для продолжения..." ;;
            4) enable_bbr ; read -rp "Нажмите Enter для продолжения..." ;;
            0) return ;;
            *) echo -e "${RED}Неизвестное действие.${NC}" ; sleep 1 ;;
        esac
    done
}

menu() {
    while true; do
        show_dashboard
        read -rp "Выберите пункт меню: " choice
        case "$choice" in
            1) show_status_detailed ;;
            2) show_access_links ;;
            3) client_manager_menu ;;
            4) network_settings_menu ;;
            5) change_admin_password ;;
            6) enable_ip_https ;;
            7) diagnostics_menu ;;
            8) backups_menu ;;
            9) restart_panel ;;
            0) exit 0 ;;
            *) echo -e "${RED}Неизвестный пункт меню.${NC}" ; sleep 1 ;;
        esac
    done
}

