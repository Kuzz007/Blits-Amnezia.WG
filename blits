create_client_interactive() {
    echo -e "\n${BOLD}--- СОЗДАНИЕ НОВОГО КЛИЕНТА ---${NC}"
    read -rp "Имя клиента (например, client_ivan): " name
    if [ -z "$name" ]; then
        echo -e "${RED}Имя не может быть пустым.${NC}"
        sleep 1.5
        return
    fi
    read -rp "Срок действия в днях [30]: " days
    days="${days:-30}"
    read -rp "Лимит трафика в ГБ (0 для безлимита) [0]: " limit
    limit="${limit:-0}"
    
    echo -e "${YELLOW}Генерация ключей и добавление клиента...${NC}"
    local res
    res=$(run_py create "$name" "$days" "$limit")
    
    if [[ "$res" == SUCCESS* ]]; then
        local ip
        ip=$(echo "$res" | cut -d';' -f3)
        echo -e "${GREEN}Клиент успешно создан! Локальный IP: $ip${NC}"
    else
        echo -e "${RED}Ошибка создания клиента: $res${NC}"
    fi
    sleep 2
}

manage_selected_client() {
    local client_id="$1"
    local client_name="$2"
    
    while true; do
        clear
        echo -e "${CYAN}=========================================================================${NC}"
        echo -e "👤 Клиент: ${BOLD}$client_name${NC} (ID: $client_id)"
        echo -e "${CYAN}=========================================================================${NC}"
        
        local details
        details=$(run_py details "$client_id")
        
        if [[ "$details" == ERROR* ]]; then
            echo -e "${RED}Ошибка получения данных: $details${NC}"
            read -rp "Нажмите Enter для продолжения..."
            return
        fi
        
        local ip limit used expires deeplink deeplink_v2
        ip=$(echo "$details" | grep "^ip:" | cut -d':' -f2-)
        limit=$(echo "$details" | grep "^limit:" | cut -d':' -f2-)
        used=$(echo "$details" | grep "^used:" | cut -d':' -f2-)
        expires=$(echo "$details" | grep "^expires:" | cut -d':' -f2-)
        deeplink=$(echo "$details" | grep "^deeplink:" | cut -d':' -f2-)
        deeplink_v2=$(echo "$details" | grep "^deeplink_v2:" | cut -d':' -f2-)
        
        local used_gb
        used_gb=$(awk "BEGIN {print $used / 1024 / 1024 / 1024}")
        local limit_str="${limit} GB"
        if [ "$limit" = "0.0" ] || [ "$limit" = "0" ]; then
            limit_str="Безлимит"
        fi
        
        echo -e "  ${BOLD}Локальный IP:${NC} $ip"
        echo -e "  ${BOLD}Трафик:${NC} $(printf "%.2f" "$used_gb") GB / $limit_str"
        echo -e "  ${BOLD}Истекает:${NC} $expires"
        echo -e "  ${BOLD}Deep Link (Amnezia v2):${NC} $deeplink_v2"
        echo -e "-------------------------------------------------------------------------"
        echo -e "  ${BOLD}1)${NC} 📱 Показать AmneziaWG QR-код в терминале"
        echo -e "  ${BOLD}2)${NC} 📱 Показать Legacy WireGuard QR-код в терминале"
        echo -e "  ${BOLD}3)${NC} 📄 Показать AmneziaWG конфиг как текст"
        echo -e "  ${BOLD}4)${NC} 📄 Показать Legacy WireGuard конфиг как текст"
        echo -e "  ${BOLD}5)${NC} 📅 Продлить подписку"
        echo -e "  ${BOLD}6)${NC} 🚫 Заблокировать / Разблокировать"
        echo -e "  ${BOLD}7)${NC} 🗑️ Удалить клиента"
        echo -e "  ${BOLD}0)${NC} ↩️ Назад к списку клиентов"
        echo -e "${CYAN}=========================================================================${NC}"
        
        read -rp "Выберите действие: " choice
        case "$choice" in
            1)
                echo -e "\n${BOLD}Отсканируйте этот QR-код приложением AmneziaVPN (AmneziaWG):${NC}"
                run_py qr "$client_id"
                read -rp "Нажмите Enter для продолжения..."
                ;;
            2)
                echo -e "\n${BOLD}Отсканируйте этот QR-код приложением WireGuard (Legacy):${NC}"
                run_py qr "$client_id" "legacy"
                read -rp "Нажмите Enter для продолжения..."
                ;;
            3)
                echo -e "\n${BOLD}--- КОНФИГУРАЦИЯ AMNEZIAWG ---${NC}"
                echo "$details" | sed -n '/===CONFIG===/,/===CONFIG_LEGACY===/p' | grep -v '==='
                read -rp "Нажмите Enter для продолжения..."
                ;;
            4)
                echo -e "\n${BOLD}--- КОНФИГУРАЦИЯ LEGACY WIREGUARD ---${NC}"
                echo "$details" | sed -n '/===CONFIG_LEGACY===/,$p' | grep -v '==='
                read -rp "Нажмите Enter для продолжения..."
                ;;
            5)
                read -rp "На сколько дней продлить?: " days
                if [[ "$days" =~ ^[0-9]+$ ]]; then
                    local res
                    res=$(run_py extend "$client_id" "$days")
                    if [[ "$res" == SUCCESS* ]]; then
                        echo -e "${GREEN}Подписка успешно продлена!${NC}"
                    else
                        echo -e "${RED}Ошибка: $res${NC}"
                    fi
                else
                    echo -e "${RED}Некорректное количество дней.${NC}"
                fi
                sleep 1.5
                ;;
            6)
                local status_check
                status_check=$(run_py list | grep ";$client_id;" | cut -d';' -f8)
                if [ "$status_check" = "BLOCKED" ]; then
                    echo -e "${YELLOW}Активация клиента...${NC}"
                    run_py enable "$client_id" >/dev/null
                    echo -e "${GREEN}Клиент успешно активирован!${NC}"
                else
                    echo -e "${YELLOW}Блокировка клиента...${NC}"
                    run_py disable "$client_id" >/dev/null
                    echo -e "${RED}Клиент успешно заблокирован!${NC}"
                fi
                sleep 1.5
                ;;
            7)
                read -rp "Вы действительно хотите УДАЛИТЬ клиента $client_name? (y/n): " confirm
                if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
                    run_py delete "$client_id" >/dev/null
                    echo -e "${RED}Клиент удален из базы данных.${NC}"
                    sleep 1.5
                    return
                fi
                ;;
            0)
                return
                ;;
            *)
                echo -e "${RED}Неизвестное действие.${NC}"
                sleep 1
                ;;
        esac
    done
}

client_manager_menu() {
    while true; do
        clear
        echo -e "${CYAN}=========================================================================${NC}"
        echo -e "👥                       ${BOLD}УПРАВЛЕНИЕ VPN КЛИЕНТАМИ${NC}                         👥"
        echo -e "${CYAN}=========================================================================${NC}"
        
        local clients_data
        clients_data=$(run_py list)
        
        if [ "$clients_data" = "CONTAINER_DOWN" ]; then
            echo -e "${RED}Ошибка: контейнер amnezia-panel выключен!${NC}"
            read -rp "Нажмите Enter для продолжения..."
            return
        elif [ "$clients_data" = "EMPTY" ] || [ -z "$clients_data" ]; then
            echo -e "Клиентов в базе данных нет."
            echo -e "-------------------------------------------------------------------------"
            echo -e "1) ➕ Создать нового клиента"
            echo -e "0) ↩️ Вернуться в главное меню"
            echo -e "-------------------------------------------------------------------------"
            read -rp "Выберите: " action
            if [ "$action" = "1" ]; then
                create_client_interactive
            elif [ "$action" = "0" ]; then
                return
            fi
        else
            printf "${BOLD}%-4s %-22s %-15s %-22s %-10s${NC}\n" "#" "Имя клиента" "IP Адрес" "Трафик (Использовано/Лимит)" "Статус"
            echo -e "-------------------------------------------------------------------------"
            
            local count=0
            declare -A c_ids
            declare -A c_names
            
            # Разбираем построчно
            while IFS=';' read -r idx id name ip used limit expires status; do
                count=$idx
                c_ids[$idx]="$id"
                c_names[$idx]="$name"
                
                local status_color="$GREEN"
                if [ "$status" = "EXPIRED" ]; then
                    status_color="$RED"
                elif [ "$status" = "BLOCKED" ]; then
                    status_color="$YELLOW"
                fi
                
                local limit_str="${limit} GB"
                if [ "$limit" = "0.0" ]; then
                    limit_str="Безлимит"
                fi
                
                printf "%-4s %-22s %-15s %-22s %b%-10s%b\n" \
                    "$idx" "$name" "$ip" "${used} / ${limit_str}" "$status_color" "$status" "$NC"
            done <<< "$clients_data"
            
            echo -e "-------------------------------------------------------------------------"
            echo -e "➕ Введите ${BOLD}C${NC} для создания нового клиента"
            echo -e "↩️ Введите ${BOLD}0${NC} для выхода"
            echo -e "👉 Выберите номер клиента ${BOLD}(1-$count)${NC} для просмотра QR/действий"
            echo -e "-------------------------------------------------------------------------"
            
            read -rp "Ваш выбор: " action
            if [ "$action" = "0" ]; then
                return
            elif [ "$action" = "c" ] || [ "$action" = "C" ]; then
                create_client_interactive
            elif [[ "$action" =~ ^[0-9]+$ ]] && [ "$action" -le "$count" ] && [ "$action" -gt 0 ]; then
                manage_selected_client "${c_ids[$action]}" "${c_names[$action]}"
            else
                echo -e "${RED}Неверный ввод.${NC}"
                sleep 1
            fi
        fi
    done
}

