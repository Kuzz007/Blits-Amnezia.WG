#!/usr/bin/env bash
set -euo pipefail

# Цветовая схема
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
BOLD='\033[1m'
GRAY='\033[0;90m'
NC='\033[0m' # No Color

APP_DIR="${BLITS_INSTALL_DIR:-/root/Blits-Amnezia.WG}"
if [ ! -d "$APP_DIR" ] && [ -d "/opt/blitz-amnezia-panel" ]; then
    APP_DIR="/opt/blitz-amnezia-panel"
fi
ENV_FILE="$APP_DIR/data/panel.env"
DB_FILE="$APP_DIR/data/panel.db"

require_root() {
    if [ "${EUID:-$(id -u)}" -ne 0 ]; then
        echo -e "${RED}Ошибка: Запустите скрипт от имени суперпользователя root.${NC}"
        exit 1
    fi
}

ensure_env() {
    mkdir -p "$(dirname "$ENV_FILE")"
    touch "$ENV_FILE"
    chmod 600 "$ENV_FILE" 2>/dev/null || true
}

get_env() {
    grep -E "^$1=" "$ENV_FILE" 2>/dev/null | tail -n1 | cut -d= -f2- || true
}

set_env() {
    ensure_env
    local key="$1"
    local value="$2"
    if grep -qE "^${key}=" "$ENV_FILE"; then
        sed -i "s|^${key}=.*|${key}=${value}|" "$ENV_FILE"
    else
        printf '%s=%s\n' "$key" "$value" >> "$ENV_FILE"
    fi
}

# Определение команды Docker Compose
DOCKER_COMPOSE_CMD="docker compose"
if docker compose version >/dev/null 2>&1; then
    DOCKER_COMPOSE_CMD="docker compose"
elif command -v docker-compose >/dev/null 2>&1; then
    DOCKER_COMPOSE_CMD="docker-compose"
fi

restart_panel() {
    echo -e "${YELLOW}Перезапуск контейнеров панели...${NC}"
    cd "$APP_DIR"
    if [ "$(get_env PANEL_HTTPS)" = "1" ]; then
        $DOCKER_COMPOSE_CMD --profile ssl up -d --build
    else
        $DOCKER_COMPOSE_CMD up -d --build
    fi
    echo -e "${GREEN}Панель перезапущена успешно.${NC}"
}

public_ip() {
    curl -fsS https://api.ipify.org 2>/dev/null || hostname -I | awk '{print $1}'
}

generate_web_path() {
    printf '/blits-%s\n' "$(openssl rand -hex 16)"
}

wait_for_apt_locks() {
    local waited=0
    while fuser /var/lib/dpkg/lock-frontend >/dev/null 2>&1 || \
          fuser /var/lib/dpkg/lock >/dev/null 2>&1 || \
          fuser /var/cache/apt/archives/lock >/dev/null 2>&1; do
        if [ "$waited" -ge 300 ]; then
            echo -e "${RED}Система обновлений apt/dpkg заблокирована более 5 минут. Попробуйте позже.${NC}" >&2
            return 1
        fi
        echo -e "${YELLOW}Система apt/dpkg занята, ожидаем 10 секунд...${NC}" >&2
        sleep 10
        waited=$((waited + 10))
    done
}

apt_update() {
    wait_for_apt_locks
    DEBIAN_FRONTEND=noninteractive apt-get update
}

apt_install() {
    wait_for_apt_locks
    DEBIAN_FRONTEND=noninteractive apt-get install -y "$@"
}

panel_url() {
    local port web_path domain scheme host https
    port="$(get_env PANEL_PORT)"
    web_path="$(get_env PANEL_WEB_PATH)"
    domain="$(get_env PANEL_DOMAIN)"
    https="$(get_env PANEL_HTTPS)"
    port="${port:-80}"
    web_path="${web_path:-/}"
    scheme="http"
    if [ "$https" = "1" ]; then
        scheme="https"
    fi
    host="${domain:-$(public_ip)}"
    if { [ "$scheme" = "http" ] && [ "$port" = "80" ]; } || { [ "$scheme" = "https" ] && [ "$port" = "443" ]; } || [ "$https" = "1" ]; then
        printf '%s://%s%s\n' "$scheme" "$host" "$web_path"
    else
        printf '%s://%s:%s%s\n' "$scheme" "$host" "$port" "$web_path"
    fi
}

# Встроенный Python-мост для работы с клиентами в контейнере
PYTHON_BRIDGE=$(cat <<'EOF'
import sys
import os
import sqlite3
import json
import datetime
import uuid
import re

sys.path.append('/app')

from app.database import get_db_connection
from app.vpn_manager import (
    generate_keypair, generate_preshared_key, get_next_free_ip,
    generate_client_config, generate_legacy_client_config, generate_amnezia_deeplink,
    rebuild_and_sync_vpn_config, log_event
)
from app.config import CLIENTS_DIR, QR_DIR

cmd = sys.argv[1] if len(sys.argv) > 1 else 'list'

if cmd == 'counts':
    conn = get_db_connection()
    now = datetime.datetime.utcnow().isoformat()
    total = conn.execute("SELECT COUNT(*) FROM clients WHERE deleted_at IS NULL").fetchone()[0]
    active = conn.execute("SELECT COUNT(*) FROM clients WHERE deleted_at IS NULL AND (disabled_at IS NULL OR disabled_at = '') AND expires_at > ?", (now,)).fetchone()[0]
    expired = conn.execute("SELECT COUNT(*) FROM clients WHERE deleted_at IS NULL AND expires_at <= ? AND (disabled_at IS NULL OR disabled_at = '')", (now,)).fetchone()[0]
    blocked = conn.execute("SELECT COUNT(*) FROM clients WHERE deleted_at IS NULL AND disabled_at IS NOT NULL AND disabled_at != ''").fetchone()[0]
    print(f"{total} {active} {expired} {blocked}")
    conn.close()

elif cmd == 'list':
    conn = get_db_connection()
    now = datetime.datetime.utcnow().isoformat()
    rows = conn.execute("SELECT id, name, ip_address, traffic_limit_gb, traffic_used_bytes, expires_at, disabled_at FROM clients WHERE deleted_at IS NULL").fetchall()
    if not rows:
        print("EMPTY")
    else:
        for idx, r in enumerate(rows, 1):
            used_gb = r['traffic_used_bytes'] / (1024**3)
            limit_gb = r['traffic_limit_gb']
            is_expired = r['expires_at'] <= now
            status = "BLOCKED" if r['disabled_at'] else ("EXPIRED" if is_expired else "ACTIVE")
            
            try:
                exp_show = datetime.datetime.fromisoformat(r['expires_at']).strftime("%Y-%m-%d")
            except:
                exp_show = r['expires_at'][:10]
            
            print(f"{idx};{r['id']};{r['name']};{r['ip_address']};{used_gb:.2f};{limit_gb:.1f};{exp_show};{status}")
    conn.close()

elif cmd == 'create':
    name = sys.argv[2]
    days = int(sys.argv[3])
    traffic_limit = float(sys.argv[4])
    
    name = re.sub(r'[\r\n]', ' ', name).strip()
    name = re.sub(r'[\\\'"`;|&<>$]', '', name)
    if not name:
        name = "client"
        
    client_id = str(uuid.uuid4())
    client_private_key, client_public_key = generate_keypair()
    preshared_key = generate_preshared_key()
    client_ip = get_next_free_ip()
    
    now = datetime.datetime.utcnow()
    created_at = now.isoformat()
    expires_at = (now + datetime.timedelta(days=days)).isoformat()
    
    conn = get_db_connection()
    conn.execute(
        """
        INSERT INTO clients (
            id, name, ip_address, public_key, private_key, preshared_key,
            traffic_limit_gb, traffic_used_bytes, expires_at, created_at
        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """,
        (client_id, name, client_ip, client_public_key, client_private_key, preshared_key, traffic_limit, 0, expires_at, created_at)
    )
    conn.commit()
    conn.close()
    
    config_text = generate_client_config(client_ip, client_private_key, preshared_key=preshared_key)
    with open(CLIENTS_DIR / f"{client_id}.conf", "w") as f:
        f.write(config_text)
        
    import qrcode
    qr = qrcode.QRCode(version=1, box_size=10, border=3)
    qr.add_data(config_text)
    qr.make(fit=True)
    qr_img = qr.make_image(fill_color="black", back_color="white")
    qr_img.save(QR_DIR / f"{client_id}.png")
    
    rebuild_and_sync_vpn_config()
    log_event("client_created", f"Создан клиент {name} через CLI.", client_id, name)
    print(f"SUCCESS;{client_id};{client_ip}")

elif cmd == 'disable':
    client_id = sys.argv[2]
    conn = get_db_connection()
    client = conn.execute("SELECT name FROM clients WHERE id = ?", (client_id,)).fetchone()
    if client:
        now = datetime.datetime.utcnow().isoformat()
        conn.execute("UPDATE clients SET disabled_at = ? WHERE id = ?", (now, client_id))
        conn.commit()
        rebuild_and_sync_vpn_config()
        log_event("client_disabled", f"Клиент {client['name']} отключен через CLI.", client_id, client['name'])
        print("SUCCESS")
    else:
        print("ERROR: Not found")
    conn.close()

elif cmd == 'enable':
    client_id = sys.argv[2]
    conn = get_db_connection()
    client = conn.execute("SELECT name FROM clients WHERE id = ?", (client_id,)).fetchone()
    if client:
        conn.execute("UPDATE clients SET disabled_at = NULL WHERE id = ?", (client_id,))
        conn.commit()
        rebuild_and_sync_vpn_config()
        log_event("client_enabled", f"Клиент {client['name']} включен через CLI.", client_id, client['name'])
        print("SUCCESS")
    else:
        print("ERROR: Not found")
    conn.close()

elif cmd == 'extend':
    client_id = sys.argv[2]
    days = int(sys.argv[3])
    conn = get_db_connection()
    client = conn.execute("SELECT name, expires_at FROM clients WHERE id = ?", (client_id,)).fetchone()
    if client:
        current_expire = datetime.datetime.fromisoformat(client['expires_at'])
        if current_expire < datetime.datetime.utcnow():
            current_expire = datetime.datetime.utcnow()
        new_expire = (current_expire + datetime.timedelta(days=days)).isoformat()
        conn.execute("UPDATE clients SET expires_at = ?, disabled_at = NULL WHERE id = ?", (new_expire, client_id))
        conn.commit()
        rebuild_and_sync_vpn_config()
        log_event("client_extended", f"Клиент {client['name']} продлен на {days} дн. через CLI.", client_id, client['name'])
        print(f"SUCCESS;{new_expire}")
    else:
        print("ERROR: Not found")
    conn.close()

elif cmd == 'delete':
    client_id = sys.argv[2]
    conn = get_db_connection()
    client = conn.execute("SELECT name FROM clients WHERE id = ?", (client_id,)).fetchone()
    if client:
        now = datetime.datetime.utcnow().isoformat()
        conn.execute("UPDATE clients SET deleted_at = ? WHERE id = ?", (now, client_id))
        conn.commit()
        rebuild_and_sync_vpn_config()
        log_event("client_deleted", f"Клиент {client['name']} удален через CLI.", client_id, client['name'])
        print("SUCCESS")
    else:
        print("ERROR: Not found")
    conn.close()

elif cmd == 'details':
    client_id = sys.argv[2]
    conn = get_db_connection()
    client = conn.execute("SELECT * FROM clients WHERE id = ?", (client_id,)).fetchone()
    if client:
        config_text = generate_client_config(client['ip_address'], client['private_key'], preshared_key=client['preshared_key'])
        config_text_legacy = generate_legacy_client_config(client['ip_address'], client['private_key'], preshared_key=client['preshared_key'])
        deep_link = generate_amnezia_deeplink(config_text_legacy, version="1.0", client_public_key=client['public_key'], client_name=client['name'])
        deep_link_v2 = generate_amnezia_deeplink(config_text, version="2.0", client_public_key=client['public_key'], client_name=client['name'])
        
        print("===DETAILS===")
        print(f"id:{client['id']}")
        print(f"name:{client['name']}")
        print(f"ip:{client['ip_address']}")
        print(f"pubkey:{client['public_key']}")
        print(f"limit:{client['traffic_limit_gb']}")
        print(f"used:{client['traffic_used_bytes']}")
        print(f"expires:{client['expires_at']}")
        print(f"deeplink:{deep_link}")
        print(f"deeplink_v2:{deep_link_v2}")
        print("===CONFIG===")
        print(config_text)
        print("===CONFIG_LEGACY===")
        print(config_text_legacy)
    else:
        print("ERROR: Not found")
    conn.close()

elif cmd == 'qr':
    client_id = sys.argv[2]
    legacy = len(sys.argv) > 3 and sys.argv[3] == 'legacy'
    conn = get_db_connection()
    client = conn.execute("SELECT * FROM clients WHERE id = ?", (client_id,)).fetchone()
    if client:
        if legacy:
            config_text = generate_legacy_client_config(client['ip_address'], client['private_key'], preshared_key=client['preshared_key'])
        else:
            config_text = generate_client_config(client['ip_address'], client['private_key'], preshared_key=client['preshared_key'])
        import qrcode
        qr = qrcode.QRCode(version=1, box_size=1, border=1)
        qr.add_data(config_text)
        qr.make(fit=True)
        qr.print_ascii(out=sys.stdout, invert=True)
    conn.close()
EOF
)

run_py() {
    if ! docker ps --format '{{.Names}}' | grep -q 'amnezia-panel'; then
        echo "CONTAINER_DOWN"
        return
    fi
    docker exec -i amnezia-panel python3 - "$@" <<< "$PYTHON_BRIDGE"
}

get_system_metrics() {
    # Uptime
    UPTIME=$(uptime -p | sed 's/up //g' 2>/dev/null || uptime | awk -F'up ' '{print $2}' | cut -d, -f1)
    
    # CPU
    CPU_LOAD=$(uptime | awk -F'load average:' '{ print $2 }' | cut -d, -f1 | sed 's/ //g' 2>/dev/null || echo "N/A")
    
    # RAM
    if command -v free >/dev/null 2>&1; then
        local ram_u ram_t
        ram_u=$(free -m | awk '/Mem:/ { print $3 }')
        ram_t=$(free -m | awk '/Mem:/ { print $2 }')
        RAM_INFO="${ram_u}/${ram_t} MB"
    else
        RAM_INFO="N/A"
    fi
    
    # Disk
    DISK_INFO=$(df -h / | awk '/\// { print $3 "/" $2 " (" $5 ")" }' | tail -n1 2>/dev/null || echo "N/A")
    
    # BBR status
    if sysctl net.ipv4.tcp_congestion_control 2>/dev/null | grep -q bbr; then
        BBR_STATUS="${GREEN}ВКЛЮЧЕН${NC}"
    else
        BBR_STATUS="${RED}ВЫКЛЮЧЕН (Нажмите 8)${NC}"
    fi
    
    # Container Status
    if docker ps --format '{{.Names}}' | grep -q 'amnezia-panel'; then
        DOCKER_STATUS="${GREEN}ЗАПУЩЕН${NC}"
    else
        DOCKER_STATUS="${RED}ОСТАНОВЛЕН${NC}"
    fi
    
    # VPN Stats
    local counts_out
    counts_out=$(run_py counts)
    if [ "$counts_out" = "CONTAINER_DOWN" ] || [ -z "$counts_out" ]; then
        CLIENTS_INFO="N/A (Контейнер оффлайн)"
    else
        local total active expired blocked
        total=$(echo "$counts_out" | awk '{print $1}')
        active=$(echo "$counts_out" | awk '{print $2}')
        expired=$(echo "$counts_out" | awk '{print $3}')
        blocked=$(echo "$counts_out" | awk '{print $4}')
        CLIENTS_INFO="${GREEN}Активно: $active${NC} | ${RED}Истекли: $expired${NC} | ${YELLOW}Заблочено: $blocked${NC} | Всего: $total"
    fi
}

